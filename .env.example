NODE_ENV=development
PORT=3000
BOT_TOKEN=telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.ru/webhook/telegram
TELEGRAM_SECRET_TOKEN=replace_with_strong_random_string
BOT_MODE=polling
ALLOWED_USER_IDS=123456789,987654321
DATABASE_URL=postgresql://bot:bot@postgres:5432/bot?schema=public
REDIS_URL=redis://redis:6379
OPENAI_API_KEY=your_api_key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_MS=20000
RATE_LIMIT_PER_MINUTE=20
LOG_LEVEL=info
